{
  "name": "@ambienceai/mcp-server",
  "version": "1.1.1",
  "description": "Ambience AI MCP Server - Generate images, videos, and audio through Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ambienceai-mcp": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ambienceai/ambienceai-mcp.git"
  },
  "homepage": "https://www.ambienceai.com/guides/connect-claude-mcp",
  "bugs": {
    "url": "https://github.com/ambienceai/ambienceai-mcp/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run clean && npm run typecheck && npm test && npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:server": "node test-server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ambience-ai",
    "image-generation",
    "video-generation",
    "audio-generation"
  ],
  "author": "Ambience AI",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "axios": "^1.11.0",
    "dotenv": "^17.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "jest": "^30.2.0",
    "prettier": "3.9.5",
    "ts-jest": "^29.4.6",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  }
}
